---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CardEtude from '../../components/CardEtude.astro';
import { getCollection } from 'astro:content';
import { url } from '../../i18n/utils';

const etudes = await getCollection('etudes-de-cas', ({ data }) => data.publie === true);
const etudesTriees = etudes.sort((a, b) => a.data.ordre - b.data.ordre);

// Extraire tous les tags uniques pour les filtres
const tousLesTags = [...new Set(etudesTriees.flatMap(e => e.data.tags))].sort();
---

<BaseLayout
  title="Études de cas | Grégor Van Dijk"
  description="8 études de cas détaillées parmi toutes les visites : flux de production, organisation, points forts, axes d'amélioration et enseignement principal."
>
  <div class="max-w-[1320px] mx-auto px-6 py-12">
    <p class="text-xs text-accent font-semibold uppercase tracking-wide">8 études · USA, Colombie & France</p>
    <h1 class="text-primary mt-2">Études de cas</h1>
    <p class="text-secondary mt-4">Analyse détaillée des ateliers visités : flux de production, organisation, points forts, axes d'amélioration et enseignement principal.</p>

    <!-- Filtres par compétence -->
    <div class="mt-8 flex flex-wrap gap-2" id="filtres" role="toolbar" aria-label="Filtrer par compétence">
      <button
        class="filtre-btn text-xs px-3 py-1.5 rounded-full border border-accent bg-accent text-white font-medium transition-colors focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 outline-none"
        data-tag="all"
        aria-pressed="true"
      >
        Toutes <span class="ml-1 opacity-75">({etudesTriees.length})</span>
      </button>
      {tousLesTags.map((tag) => {
        const count = etudesTriees.filter(e => e.data.tags.includes(tag)).length;
        return (
          <button
            class="filtre-btn text-xs px-3 py-1.5 rounded-full border border-border bg-white text-secondary font-medium hover:border-accent hover:text-accent transition-colors focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 outline-none"
            data-tag={tag}
            aria-pressed="false"
          >
            {tag} <span class="ml-1 opacity-75">({count})</span>
          </button>
        );
      })}
    </div>

    {etudesTriees.length > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 md:gap-6 mt-6" id="grille">
        {etudesTriees.map((etude) => (
          <div data-tags={JSON.stringify(etude.data.tags)}>
            <CardEtude
              titre={etude.data.titre}
              pays={etude.data.pays}
              ville={etude.data.ville}
              taille={etude.data.taille}
              duree={etude.data.duree}
              image={etude.data.image}
              imageAlt={etude.data.imageAlt}
              resume={etude.data.resume}
              tags={etude.data.tags}
              slug={etude.id}
              contact={etude.data.contact}
            />
          </div>
        ))}
      </div>
    ) : (
      <p class="text-secondary mt-10">Aucune étude de cas disponible pour le moment.</p>
    )}

    <p id="aucun-resultat" class="text-secondary mt-10 hidden">Aucune étude ne correspond à ce filtre.</p>

    <!-- Limites & Opportunités -->
    <a
      href={url('/limites/')}
      class="group mt-12 block p-6 rounded-xl border border-accent/20 bg-accent/[0.03] hover:shadow-lg hover:-translate-y-0.5 transition-all duration-200 ease-out focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 outline-none"
    >
      <p class="text-xs text-accent font-semibold uppercase tracking-wide">Analyse transversale</p>
      <p class="text-primary font-semibold mt-2">Limites & Opportunités</p>
      <p class="text-secondary text-sm mt-2 leading-relaxed">Analyse des contraintes structurelles et des leviers de développement observés dans les ateliers et usines visités.</p>
      <span class="inline-flex items-center gap-1 text-accent text-sm font-medium mt-3 group-hover:gap-2 transition-all">Lire l'analyse →</span>
    </a>

    <hr class="border-border mt-12" />
    <div class="flex justify-between mt-8">
      <a
        href={url('/')}
        class="inline-flex items-center gap-1 text-accent hover:text-accent-hover font-medium transition-colors focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 outline-none rounded"
      >
        ← Accueil
      </a>
      <a
        href={url('/pays-et-culture/')}
        class="inline-flex items-center gap-1 text-accent hover:text-accent-hover font-medium transition-colors focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 outline-none rounded"
      >
        Pays & Culture →
      </a>
    </div>
  </div>
</BaseLayout>

<script>
  const btns = document.querySelectorAll<HTMLButtonElement>('.filtre-btn');
  const cards = document.querySelectorAll<HTMLElement>('#grille > div');
  const aucun = document.getElementById('aucun-resultat');

  btns.forEach(btn => {
    btn.addEventListener('click', () => {
      const tag = btn.dataset.tag!;

      // Update active state
      btns.forEach(b => {
        b.setAttribute('aria-pressed', 'false');
        b.classList.remove('bg-accent', 'text-white', 'border-accent');
        b.classList.add('bg-white', 'text-secondary', 'border-border');
      });
      btn.setAttribute('aria-pressed', 'true');
      btn.classList.remove('bg-white', 'text-secondary', 'border-border');
      btn.classList.add('bg-accent', 'text-white', 'border-accent');

      // Filter cards
      let visible = 0;
      cards.forEach(card => {
        const tags: string[] = JSON.parse(card.dataset.tags || '[]');
        const show = tag === 'all' || tags.includes(tag);
        card.style.display = show ? '' : 'none';
        if (show) visible++;
      });

      // Show/hide empty state
      if (aucun) {
        aucun.classList.toggle('hidden', visible > 0);
      }
    });
  });
</script>
