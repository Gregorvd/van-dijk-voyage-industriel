---
import BaseLayout from '../layouts/BaseLayout.astro';
import BoutonCTA from '../components/BoutonCTA.astro';
---

<BaseLayout
  title="Page introuvable — Voyage industriel"
  description="La page demandée n'existe pas."
>
  <div class="flex flex-col items-center justify-center min-h-[50vh] text-center px-6">
    <h1 class="text-primary">Page introuvable</h1>
    <p class="text-secondary mt-4 max-w-md">
      La page que vous cherchez n'existe pas ou a été déplacée.
    </p>
    <div class="mt-8">
      <BoutonCTA label="Retour à l'accueil" href="/" variant="secondary" />
    </div>
  </div>
</BaseLayout>
