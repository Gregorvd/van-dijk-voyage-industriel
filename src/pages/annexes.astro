---
import BaseLayout from '../layouts/BaseLayout.astro';
import { url } from '../i18n/utils';

const sections = [
  {
    titre: 'Portland, capitale cycliste',
    photos: [
      { src: '/images/photos/portland-garage-velo-hopital.webp', alt: 'Parking vélo massif devant un hôpital à Portland', legende: 'Parking vélo massif « Go By Bike » devant les cabines qui montent à l\'hôpital de Portland' },
      { src: '/images/photos/portland-go-by-bike.webp', alt: 'Kiosque de réparation Go By Bike à Portland', legende: 'Kiosque de réparation « Go By Bike » installé a l\'entrée du parking à vélo' },
      { src: '/images/photos/portland-bicycle-polo.webp', alt: 'Terrain de bicycle polo en plein air à Portland', legende: 'Terrain de bicycle polo en plein air, sport communautaire populaire à Portland' },
    ],
  },
  {
    titre: 'Marin Museum of Bicycling, Fairfax',
    photos: [
      { src: '/images/photos/sf-musee-velo-design.webp', alt: 'Bowden Spacelander, vélo au design futuriste des années 60 au musée de San Francisco', legende: 'Bowden Spacelander (1960) : cadre monocoque en fibre de verre, icône du design industriel' },
      { src: '/images/photos/sf-musee-velo-titane.webp', alt: 'Vélo titane sans chaîne avec suspension arrière intégrée au musée de San Francisco', legende: 'Vélo titane sans chaîne avec suspension arrière intégrée, raccords apparents, finition brute sans peinture' },
      { src: '/images/photos/sf-musee-velo-ancien.webp', alt: 'Vélo ancien avec cadre en bois au musée de San Francisco', legende: 'Vélo ancien avec triangle de cadre en bois, début du XXe siècle' },
    ],
  },
  {
    titre: 'Atelier Frances Cycles',
    photos: [
      { src: '/images/photos/usa-atelier-garage-1.webp', alt: 'Atelier garage d\'un framebuilder avec outillage accumulé sur des décennies', legende: 'Atelier Frances Cycles à Santa Cruz de Joshua Muir' },
      { src: '/images/photos/usa-atelier-garage-3.webp', alt: 'Atelier garage avec fraiseuse et tubes acier stockés au plafond à Santa Cruz', legende: 'Fraiseuse, tubes acier au plafond : réalisation de Joshua Muir, Santa Cruz' },
      { src: '/images/photos/usa-atelier-garage-velo.webp', alt: 'Tandem jaune devant un atelier garage de framebuilder à Santa Cruz', legende: 'Réalisation de Joshua Muir et vélo phare de sa production, Santa Cruz' },
    ],
  },
];
---

<BaseLayout
  title="Annexes | Grégor Van Dijk"
  description="Photos de terrain, itinéraires vélo et observations complémentaires du voyage industriel dans 12 pays."
>
  <div class="max-w-[1320px] mx-auto px-6 py-12">
    <p class="text-xs text-accent font-semibold uppercase tracking-wide">Terrain</p>
    <h1 class="text-primary mt-2">Annexes</h1>
    <p class="text-secondary mt-4">
      Photos prises sur le terrain au fil des visites : ateliers, infrastructures, culture vélo et observations diverses.
    </p>

    <div class="mt-12 space-y-16">
      {sections.map((section) => (
        <section>
          <h2 class="text-primary text-lg font-semibold">{section.titre}</h2>
          <div class={`mt-4 grid gap-4 ${section.photos.length === 1 ? 'grid-cols-1 max-w-lg' : section.photos.length === 2 ? 'grid-cols-1 sm:grid-cols-2' : 'grid-cols-1 sm:grid-cols-2 lg:grid-cols-3'}`}>
            {section.photos.map((photo) => (
              <figure class="m-0 min-w-0 flex flex-col items-center">
                <img
                  src={photo.src}
                  alt={photo.alt}
                  class="max-h-[400px] max-w-full rounded-lg border border-border"
                  loading="lazy"
                />
                <figcaption class="text-[11px] text-secondary mt-1.5 text-center leading-relaxed">{photo.legende}</figcaption>
              </figure>
            ))}
          </div>
        </section>
      ))}
    </div>

    <hr class="border-border mt-12" />
    <div class="flex justify-start mt-8">
      <a
        href={url('/a-propos/')}
        class="inline-flex items-center gap-1 text-accent hover:text-accent-hover font-medium transition-colors focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 outline-none rounded"
      >
        ← À propos
      </a>
    </div>
  </div>
</BaseLayout>
