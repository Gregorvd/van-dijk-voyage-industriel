---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { url } from '../../i18n/utils';

const sections = [
  {
    titre: 'Portland, cycling capital',
    photos: [
      { src: '/images/photos/portland-garage-velo-hopital.webp', alt: 'Massive bicycle parking in front of a hospital in Portland', legende: 'Massive "Go By Bike" bicycle parking in front of the cable cars leading to Portland\'s hospital' },
      { src: '/images/photos/portland-go-by-bike.webp', alt: 'Go By Bike repair kiosk in Portland', legende: '"Go By Bike" repair kiosk set up at the entrance of the bicycle parking' },
      { src: '/images/photos/portland-bicycle-polo.webp', alt: 'Outdoor bicycle polo court in Portland', legende: 'Outdoor bicycle polo court, a popular community sport in Portland' },
    ],
  },
  {
    titre: 'Marin Museum of Bicycling, Fairfax',
    photos: [
      { src: '/images/photos/sf-musee-velo-design.webp', alt: 'Bowden Spacelander, futuristic 1960s bicycle design at the museum', legende: 'Bowden Spacelander (1960): fiberglass monocoque frame, industrial design icon' },
      { src: '/images/photos/sf-musee-velo-titane.webp', alt: 'Chainless titanium bicycle with integrated rear suspension at the museum', legende: 'Chainless titanium bike with integrated rear suspension, visible joints, raw unpainted finish' },
      { src: '/images/photos/sf-musee-velo-ancien.webp', alt: 'Antique bicycle with wooden frame at the museum', legende: 'Antique bicycle with wooden frame triangle, early 20th century' },
    ],
  },
  {
    titre: 'Frances Cycles Workshop',
    photos: [
      { src: '/images/photos/usa-atelier-garage-1.webp', alt: 'Framebuilder garage workshop with tools accumulated over decades', legende: 'Frances Cycles workshop in Santa Cruz by Joshua Muir' },
      { src: '/images/photos/usa-atelier-garage-3.webp', alt: 'Garage workshop with milling machine and steel tubes stored on the ceiling in Santa Cruz', legende: 'Milling machine, steel tubes on the ceiling: Joshua Muir\'s work, Santa Cruz' },
      { src: '/images/photos/usa-atelier-garage-velo.webp', alt: 'Yellow tandem in front of a framebuilder garage workshop in Santa Cruz', legende: 'Joshua Muir\'s creation and flagship bike, Santa Cruz' },
    ],
  },
];
---

<BaseLayout
  title="Appendices | Grégor Van Dijk"
  description="Field photos, cycling routes and complementary observations from the industrial journey across 12 countries."
>
  <div class="max-w-[1320px] mx-auto px-6 py-12">
    <p class="text-xs text-accent font-semibold uppercase tracking-wide">Field</p>
    <h1 class="text-primary mt-2">Appendices</h1>
    <p class="text-secondary mt-4">
      Photos taken in the field during visits: workshops, infrastructure, bike culture and various observations.
    </p>

    <div class="mt-12 space-y-16">
      {sections.map((section) => (
        <section>
          <h2 class="text-primary text-lg font-semibold">{section.titre}</h2>
          <div class={`mt-4 grid gap-4 ${section.photos.length === 1 ? 'grid-cols-1 max-w-lg' : section.photos.length === 2 ? 'grid-cols-1 sm:grid-cols-2' : 'grid-cols-1 sm:grid-cols-2 lg:grid-cols-3'}`}>
            {section.photos.map((photo) => (
              <figure class="m-0 min-w-0 flex flex-col items-center">
                <img
                  src={url(photo.src)}
                  alt={photo.alt}
                  class="max-h-[400px] max-w-full rounded-lg border border-border"
                  loading="lazy"
                />
                <figcaption class="text-[11px] text-secondary mt-1.5 text-center leading-relaxed">{photo.legende}</figcaption>
              </figure>
            ))}
          </div>
        </section>
      ))}
    </div>

    <hr class="border-border mt-12" />
    <div class="flex justify-start mt-8">
      <a
        href={url('/en/a-propos/')}
        class="inline-flex items-center gap-1 text-accent hover:text-accent-hover font-medium transition-colors focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 outline-none rounded"
      >
        &larr; About
      </a>
    </div>
  </div>
</BaseLayout>
