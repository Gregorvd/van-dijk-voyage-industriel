---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CardEtude from '../../components/CardEtude.astro';
import { getCollection } from 'astro:content';
import { url } from '../../i18n/utils';

const birthDate = new Date(2001, 0, 15);
const today = new Date();
const age = today.getFullYear() - birthDate.getFullYear() - (today < new Date(today.getFullYear(), 0, 15) ? 1 : 0);

const etudes = await getCollection('etudes-de-cas', ({ data }) => data.publie === true);
const etudesVedettes = etudes.sort((a, b) => a.data.ordre - b.data.ordre).slice(0, 3);

// Map data for visited zones
const zones = [
  { lat: 45.52, lng: -122.68, nom: 'United States', detail: 'Oregon, Washington, California', anchor: 'united-states' },
  { lat: 49.28, lng: -123.12, nom: 'Canada', detail: 'Vancouver', anchor: 'canada' },
  { lat: 4.71, lng: -74.07, nom: 'Colombia', detail: '', anchor: 'colombia' },
  { lat: -23.55, lng: -46.63, nom: 'Brazil', detail: 'São Paulo', anchor: 'brazil' },
  { lat: -33.93, lng: 18.42, nom: 'South Africa', detail: 'Cape Town, Paarl', anchor: 'south-africa' },
  { lat: -22.33, lng: 24.68, nom: 'Botswana', detail: '', anchor: 'botswana' },
  { lat: 9.93, lng: -84.08, nom: 'Costa Rica', detail: '', anchor: 'costa-rica' },
  { lat: 8.98, lng: -79.52, nom: 'Panama', detail: '', anchor: 'panama' },
  { lat: 15.87, lng: 100.99, nom: 'Thailand', detail: '', anchor: 'thailand' },
  { lat: 17.97, lng: 102.63, nom: 'Laos', detail: 'Vientiane, Luang Prabang', anchor: 'laos' },
];
---

<BaseLayout
  title="Grégor Van Dijk | Industrial Exploration & Cycling"
  description={`Industrial engineer, ${age}. 8 months, 12 countries, 30+ facilities visited. Technical project manager, French-speaking Switzerland.`}
>
  <!-- Hero section -->
  <section class="max-w-[1040px] mx-auto text-center px-6 pt-20 pb-12">
    <p class="text-sm text-secondary font-medium uppercase tracking-wide">
      Industrial engineer · {age} years old
    </p>

    <h1 class="text-primary mt-4">Grégor Van Dijk</h1>

    <p class="text-secondary mt-6 text-lg leading-relaxed">
      8 months, 12 countries, 30+ facilities visited: artisan workshops, component factories and cycling cities. This site documents a structured industrial observation journey across North America, South America and Asia.
    </p>

    <p class="text-accent/80 mt-4 italic">
      Toyota taught me the principles. The journey proved they are universal.
    </p>

    <!-- Job search banner -->
    <div class="mt-6 inline-flex items-center gap-2 px-4 py-2 rounded-full bg-accent/10 text-accent text-sm font-medium">
      <span aria-hidden="true">→</span>
      Seeking: Technical project manager · French-speaking Switzerland
    </div>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-6 mt-12">
      <div aria-label="8 months of travel">
        <p class="text-2xl font-semibold text-primary">8</p>
        <p class="text-sm text-secondary">months of travel</p>
      </div>
      <div aria-label="12 countries visited">
        <p class="text-2xl font-semibold text-primary">12</p>
        <p class="text-sm text-secondary">countries visited</p>
      </div>
      <div aria-label="Over 30 facilities observed">
        <p class="text-2xl font-semibold text-primary">30+</p>
        <p class="text-sm text-secondary">facilities observed</p>
      </div>
      <div aria-label="8 case studies">
        <p class="text-2xl font-semibold text-primary">8</p>
        <p class="text-sm text-secondary">case studies</p>
      </div>
    </div>
  </section>

  <!-- Personas — Entry points -->
  <section class="max-w-[1320px] mx-auto px-6 py-12 border-t border-border">
    <p class="text-xs text-accent font-semibold uppercase tracking-wide text-center">This site is for</p>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mt-8">
      <a href={url('/en/etudes-de-cas/')} class="group p-6 rounded-lg border border-border bg-white hover:shadow-lg hover:-translate-y-0.5 transition-all duration-200 ease-out focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 outline-none">
        <p class="text-accent font-semibold text-sm">Industrial recruiter</p>
        <p class="text-primary font-semibold mt-2">Looking for a field profile?</p>
        <p class="text-secondary text-sm mt-2 leading-relaxed">Discover 8 case studies illustrating my ability to read a production system, identify improvement levers and structure actionable observations.</p>
        <span class="inline-flex items-center gap-1 text-accent text-sm font-medium mt-4 group-hover:gap-2 transition-all">View case studies →</span>
      </a>
      <a href={url('/en/bilan/')} class="group p-6 rounded-lg border border-border bg-white hover:shadow-lg hover:-translate-y-0.5 transition-all duration-200 ease-out focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 outline-none">
        <p class="text-accent font-semibold text-sm">Technical manager</p>
        <p class="text-primary font-semibold mt-2">What concrete skills?</p>
        <p class="text-secondary text-sm mt-2 leading-relaxed">6 skill domains developed in the field: continuous improvement, industrialization, production management, coordination, innovation and cross-functional.</p>
        <span class="inline-flex items-center gap-1 text-accent text-sm font-medium mt-4 group-hover:gap-2 transition-all">View skills →</span>
      </a>
      <a href={url('/en/vision/')} class="group p-6 rounded-lg border border-border bg-white hover:shadow-lg hover:-translate-y-0.5 transition-all duration-200 ease-out focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 outline-none">
        <p class="text-accent font-semibold text-sm">Engineer / curious</p>
        <p class="text-primary font-semibold mt-2">What industrial vision?</p>
        <p class="text-secondary text-sm mt-2 leading-relaxed">What this journey taught me about the role of an industrial engineer, the limits of artisan structures and the improvement opportunities they contain.</p>
        <span class="inline-flex items-center gap-1 text-accent text-sm font-medium mt-4 group-hover:gap-2 transition-all">Read my vision →</span>
      </a>
    </div>
  </section>

  <!-- Method section -->
  <section class="max-w-[1320px] mx-auto px-6 py-16">
    <p class="text-xs text-accent font-semibold uppercase tracking-wide">Method</p>
    <h2 class="text-primary mt-2">A structured industrial observation, not a simple travel journal.</h2>

    <!-- Desktop timeline (horizontal with line) -->
    <div class="hidden md:block mt-12">
      <div class="relative">
        <!-- Horizontal connection line -->
        <div class="absolute top-5 left-[calc(16.67%-0px)] right-[calc(16.67%-0px)] h-0.5 bg-accent/20" aria-hidden="true"></div>

        <div class="grid grid-cols-3 gap-8 relative">
          <!-- Step 01 -->
          <div class="flex flex-col items-center text-center">
            <div class="relative z-10 w-10 h-10 rounded-full bg-accent text-white flex items-center justify-center font-semibold text-sm shadow-sm">01</div>
            <h3 class="text-primary font-semibold mt-4">Observe</h3>
            <p class="text-secondary mt-2 text-sm leading-relaxed max-w-xs">
              Direct workshop visits, discussions with founders and technicians, observation of production flows and workstations.
            </p>
          </div>

          <!-- Step 02 -->
          <div class="flex flex-col items-center text-center">
            <div class="relative z-10 w-10 h-10 rounded-full bg-accent text-white flex items-center justify-center font-semibold text-sm shadow-sm">02</div>
            <h3 class="text-primary font-semibold mt-4">Analyze</h3>
            <p class="text-secondary mt-2 text-sm leading-relaxed max-w-xs">
              Reading manufacturing processes, identifying strengths and areas for improvement, detecting waste and Lean practices, present or absent.
            </p>
          </div>

          <!-- Step 03 -->
          <div class="flex flex-col items-center text-center">
            <div class="relative z-10 w-10 h-10 rounded-full bg-accent text-white flex items-center justify-center font-semibold text-sm shadow-sm">03</div>
            <h3 class="text-primary font-semibold mt-4">Compare</h3>
            <p class="text-secondary mt-2 text-sm leading-relaxed max-w-xs">
              Cross-country perspective between industrial models and mobility cultures. Searching for universal patterns and applicable lessons.
            </p>
          </div>
        </div>
      </div>
    </div>

    <!-- Mobile timeline (vertical with line) -->
    <div class="md:hidden mt-10">
      <ol class="relative ml-5">
        <!-- Vertical line -->
        <div class="absolute left-0 top-5 bottom-5 w-0.5 bg-accent/20" aria-hidden="true"></div>

        <li class="relative pl-8 pb-8">
          <div class="absolute left-[-8px] top-0 z-10 w-4 h-4 rounded-full bg-accent border-2 border-white shadow-sm"></div>
          <p class="text-xs text-accent font-semibold uppercase tracking-wide">01</p>
          <h3 class="text-primary font-semibold mt-1">Observe</h3>
          <p class="text-secondary mt-2 text-sm leading-relaxed">
            Direct workshop visits, discussions with founders and technicians, observation of production flows and workstations.
          </p>
        </li>

        <li class="relative pl-8 pb-8">
          <div class="absolute left-[-8px] top-0 z-10 w-4 h-4 rounded-full bg-accent border-2 border-white shadow-sm"></div>
          <p class="text-xs text-accent font-semibold uppercase tracking-wide">02</p>
          <h3 class="text-primary font-semibold mt-1">Analyze</h3>
          <p class="text-secondary mt-2 text-sm leading-relaxed">
            Reading manufacturing processes, identifying strengths and areas for improvement, detecting waste and Lean practices, present or absent.
          </p>
        </li>

        <li class="relative pl-8">
          <div class="absolute left-[-8px] top-0 z-10 w-4 h-4 rounded-full bg-accent border-2 border-white shadow-sm"></div>
          <p class="text-xs text-accent font-semibold uppercase tracking-wide">03</p>
          <h3 class="text-primary font-semibold mt-1">Compare</h3>
          <p class="text-secondary mt-2 text-sm leading-relaxed">
            Cross-country perspective between industrial models and mobility cultures. Searching for universal patterns and applicable lessons.
          </p>
        </li>
      </ol>
    </div>
  </section>

  <!-- Skills section -->
  <section class="max-w-[1320px] mx-auto px-6 py-16 border-t border-border">
    <p class="text-xs text-accent font-semibold uppercase tracking-wide">Demonstrated skills</p>
    <h2 class="text-primary mt-2">What this approach demonstrates</h2>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 mt-10">
      <div class="p-6 rounded-lg border border-border bg-white">
        <h3 class="text-primary font-semibold">Industrial system reading</h3>
        <p class="text-secondary mt-2 text-sm leading-relaxed">
          Ability to quickly identify flows, bottlenecks and optimization levers in an unknown industrial facility, without prior documentation.
        </p>
      </div>
      <div class="p-6 rounded-lg border border-border bg-white">
        <h3 class="text-primary font-semibold">Lean analysis</h3>
        <p class="text-secondary mt-2 text-sm leading-relaxed">
          Field detection of waste, pull flow practices, visual management and continuous improvement opportunities in artisan SMEs.
        </p>
      </div>
      <div class="p-6 rounded-lg border border-border bg-white">
        <h3 class="text-primary font-semibold">International vision</h3>
        <p class="text-secondary mt-2 text-sm leading-relaxed">
          Understanding of industrial and cultural dynamics worldwide. Quick adaptation to new environments, in English and multicultural contexts.
        </p>
      </div>
      <div class="p-6 rounded-lg border border-border bg-white">
        <h3 class="text-primary font-semibold">Technical coordination</h3>
        <p class="text-secondary mt-2 text-sm leading-relaxed">
          Understanding of office–workshop–supplier interfaces and each stakeholder's constraints. Solid foundation for coordinating technical projects.
        </p>
      </div>
    </div>
  </section>

  <!-- Map section -->
  <section class="max-w-[1320px] mx-auto px-6 py-16 border-t border-border">
    <p class="text-xs text-accent font-semibold uppercase tracking-wide">Geography</p>
    <h2 class="text-primary mt-2">Countries visited</h2>
    <p class="text-secondary mt-2">
      North America · Central America · South America · Africa · Asia
    </p>

    <div class="mt-8 rounded-lg overflow-hidden border border-border" style="height: 400px;" id="carte-accueil" aria-label="Map of visited industrial facilities">
    </div>
  </section>

  <!-- Case studies section -->
  <section class="max-w-[1320px] mx-auto px-6 py-16 border-t border-border">
    <h2 class="text-primary text-center">Case Studies</h2>
    <p class="text-secondary text-center mt-2">Detailed analysis of visited workshops: production flow, organization, strengths, areas for improvement and key takeaway.</p>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mt-10">
      {etudesVedettes.map((etude) => (
        <CardEtude
          titre={etude.data.titre}
          pays={etude.data.pays}
          ville={etude.data.ville}
          taille={etude.data.taille}
          duree={etude.data.duree}
          image={etude.data.image}
          imageAlt={etude.data.imageAlt}
          resume={etude.data.resume}
          tags={etude.data.tags}
          slug={etude.id}
          contact={etude.data.contact}
          locale="en"
        />
      ))}
    </div>

    <div class="text-center mt-8">
      <a
        href={url('/en/etudes-de-cas/')}
        class="inline-flex items-center gap-1 text-accent hover:text-accent-hover font-medium transition-colors focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 outline-none rounded"
      >
        View all 8 case studies →
      </a>
    </div>
  </section>
</BaseLayout>

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<script is:inline src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script is:inline src="https://cdn.jsdelivr.net/npm/topojson-client@3/dist/topojson-client.min.js"></script>
<script is:inline define:vars={{ zones, baseUrl: import.meta.env.BASE_URL.replace(/\/$/, '') }}>
  document.addEventListener('DOMContentLoaded', async () => {
    var el = document.getElementById('carte-accueil');
    if (!el || !window.L) return;

    var map = L.map(el, { scrollWheelZoom: false }).setView([20, 0], 2);

    L.tileLayer('https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png', {
      attribution: '© <a href="https://www.openstreetmap.org/copyright">OSM</a> · © <a href="https://carto.com/">CARTO</a>',
      maxZoom: 18,
    }).addTo(map);

    var baseStyle = { fillColor: '#2C5282', fillOpacity: 0.15, color: '#2C5282', weight: 1.5 };
    var hoverStyle = { fillOpacity: 0.35, weight: 2.5 };

    var countryMap = {
      170: { nom: '🇨🇴 Colombia', detail: '', anchor: 'colombia' },
      188: { nom: '🇨🇷 Costa Rica', detail: '', anchor: 'costa-rica' },
      591: { nom: '🇵🇦 Panama', detail: '', anchor: 'panama' },
      72:  { nom: '🇧🇼 Botswana', detail: '', anchor: 'botswana' },
      764: { nom: '🇹🇭 Thailand', detail: '', anchor: 'thailand' },
      418: { nom: '🇱🇦 Laos', detail: 'Vientiane, Luang Prabang', anchor: 'laos' },
    };
    var stateMap = {
      '41': { nom: '🇺🇸 United States', detail: 'Oregon', anchor: 'united-states' },
      '53': { nom: '🇺🇸 United States', detail: 'Washington', anchor: 'united-states' },
      '06': { nom: '🇺🇸 United States', detail: 'California', anchor: 'united-states' },
    };

    function makePopup(info) {
      var html = '<strong>' + info.nom + '</strong>';
      if (info.detail) html += '<br><span style="font-size:12px;color:#64748B">' + info.detail + '</span>';
      html += '<br><a href="' + baseUrl + '/en/pays-et-culture/#' + info.anchor + '" style="color:#2C5282;font-size:12px">View section →</a>';
      return html;
    }

    function addInteraction(layer, info) {
      layer.bindPopup(makePopup(info));
      layer.on('mouseover', function() { layer.setStyle(hoverStyle); });
      layer.on('mouseout', function() { layer.setStyle(baseStyle); });
    }

    try {
      var fullIds = [170, 188, 591, 72, 764, 418];
      var res = await fetch('https://cdn.jsdelivr.net/npm/world-atlas@2/countries-110m.json');
      var topo = await res.json();
      var countries = topojson.feature(topo, topo.objects.countries);
      L.geoJSON(countries, {
        filter: function(f) { return fullIds.indexOf(Number(f.id)) !== -1; },
        style: baseStyle,
        onEachFeature: function(f, layer) {
          var info = countryMap[Number(f.id)];
          if (info) addInteraction(layer, info);
        }
      }).addTo(map);

      var stRes = await fetch('https://cdn.jsdelivr.net/npm/us-atlas@3/states-10m.json');
      var stTopo = await stRes.json();
      var states = topojson.feature(stTopo, stTopo.objects.states);
      L.geoJSON(states, {
        filter: function(f) { return ['41','53','06'].indexOf(f.id) !== -1; },
        style: baseStyle,
        onEachFeature: function(f, layer) {
          var info = stateMap[f.id];
          if (info) addInteraction(layer, info);
        }
      }).addTo(map);

      var regions = { type: 'FeatureCollection', features: [
        { type: 'Feature', properties: { nom: '🇨🇦 Canada', detail: 'Vancouver (B.C.)', anchor: 'canada' }, geometry: { type: 'Polygon', coordinates: [[[-139,60],[-114,60],[-114,49],[-122,49],[-123.2,48.7],[-125.5,48.5],[-127.5,50],[-129.5,51.5],[-131.5,53.5],[-134,55.5],[-137,58],[-139,60]]] }},
        { type: 'Feature', properties: { nom: '🇿🇦 South Africa', detail: 'Cape Town, Paarl', anchor: 'south-africa' }, geometry: { type: 'Polygon', coordinates: [[[17.5,-34.8],[18.5,-34.2],[19.3,-33.6],[20.0,-33.0],[20.7,-32.0],[20.7,-31.2],[19.5,-31.2],[18.3,-32.0],[17.5,-33.2],[17.5,-34.8]]] }},
        { type: 'Feature', properties: { nom: '🇧🇷 Brazil', detail: 'São Paulo', anchor: 'brazil' }, geometry: { type: 'Polygon', coordinates: [[[-53.1,-22.7],[-51.0,-20.8],[-49.0,-20.0],[-46.5,-20.0],[-44.2,-22.5],[-45.0,-24.7],[-47.5,-25.3],[-50.0,-25.3],[-52.0,-24.5],[-53.1,-22.7]]] }}
      ]};
      L.geoJSON(regions, {
        style: baseStyle,
        onEachFeature: function(f, layer) {
          addInteraction(layer, f.properties);
        }
      }).addTo(map);
    } catch(e) {
      console.warn('Boundaries not loaded:', e);
      el.innerHTML = '<p style="text-align:center;padding:2rem;color:#64748B">Map unavailable — check your connection.</p>';
    }

    var bounds = zones.map(function(z) { return [z.lat, z.lng]; });
    if (bounds.length > 0) {
      map.fitBounds(bounds, { padding: [30, 30], maxZoom: 3 });
    }
  });
</script>
