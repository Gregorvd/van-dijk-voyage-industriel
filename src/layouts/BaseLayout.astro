---
import '../styles/global.css';
import MetaSEO from '../components/MetaSEO.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { getLocaleFromPath, url } from '../i18n/utils';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
}

const { title, description, ogImage } = Astro.props;
const lang = getLocaleFromPath(Astro.url.pathname);
---

<!DOCTYPE html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href={url('/favicon.svg')} />
    <link rel="icon" type="image/png" sizes="32x32" href={url('/favicon-32.png')} />
    <link rel="icon" type="image/png" sizes="16x16" href={url('/favicon-16.png')} />
    <link rel="apple-touch-icon" sizes="180x180" href={url('/apple-touch-icon.png')} />
    <meta name="generator" content={Astro.generator} />
    <MetaSEO title={title} description={description} ogImage={ogImage} />
  </head>
  <body class="bg-surface text-primary">
    <a href="#main-content" class="skip-to-content">
      {lang === 'en' ? 'Skip to main content' : 'Aller au contenu principal'}
    </a>
    <Navbar />
    <main id="main-content">
      <slot />
    </main>
    <Footer />
  </body>
</html>
