---
import '../styles/global.css';
import MetaSEO from '../components/MetaSEO.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { getLocaleFromPath, url } from '../i18n/utils';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
}

const { title, description, ogImage } = Astro.props;
const lang = getLocaleFromPath(Astro.url.pathname);
const isProd = import.meta.env.PROD;
---

<!DOCTYPE html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href={url('/favicon.svg')} />
    <link rel="icon" type="image/png" sizes="32x32" href={url('/favicon-32.png')} />
    <link rel="icon" type="image/png" sizes="16x16" href={url('/favicon-16.png')} />
    <link rel="apple-touch-icon" sizes="180x180" href={url('/apple-touch-icon.png')} />
    <meta name="generator" content={Astro.generator} />
    <MetaSEO title={title} description={description} ogImage={ogImage} />
    <!-- Security meta tags -->
    <meta http-equiv="X-Content-Type-Options" content="nosniff" />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <!-- GoatCounter analytics (production only, no cookies, GDPR-friendly) -->
    {isProd && <script data-goatcounter="https://gregorvd.goatcounter.com/count" is:inline async src="//gc.zgo.at/count.js"></script>}
  </head>
  <body class="bg-surface text-primary pt-16">
    <a href="#main-content" class="skip-to-content">
      {lang === 'en' ? 'Skip to main content' : 'Aller au contenu principal'}
    </a>
    <Navbar />
    <main id="main-content">
      <slot />
    </main>
    <Footer />
    <!-- Contact obfuscation script -->
    <script is:inline>
      document.addEventListener('DOMContentLoaded', function() {
        document.querySelectorAll('.obf-email').forEach(function(el) {
          var u = el.getAttribute('data-u');
          var d = el.getAttribute('data-d');
          if (u && d) {
            var addr = u + '@' + d;
            el.setAttribute('href', 'mai' + 'lto:' + addr);
            var txt = el.querySelector('.obf-email-text');
            if (txt) txt.textContent = addr;
          }
        });
        document.querySelectorAll('.obf-phone').forEach(function(el) {
          var p = el.getAttribute('data-p');
          if (p) {
            el.setAttribute('href', 'https://wa.me/' + p);
            var txt = el.querySelector('.obf-phone-text');
            if (txt) txt.textContent = '+' + p.slice(0,2) + ' ' + p.slice(2,3) + ' ' + p.slice(3,5) + ' ' + p.slice(5,7) + ' ' + p.slice(7,9) + ' ' + p.slice(9);
          }
        });
      });
    </script>
  </body>
</html>
