---
import BoutonCTA from './BoutonCTA.astro';
import { getLocaleFromPath, getAlternatePath } from '../i18n/utils';

const currentPath = Astro.url.pathname;
const locale = getLocaleFromPath(currentPath);
const alternatePath = getAlternatePath(currentPath);

const navLinksFr = [
  { label: 'Accueil', href: '/' },
  { label: 'Études de cas', href: '/etudes-de-cas/' },
  { label: 'Pays & Culture', href: '/pays-et-culture/' },
  { label: 'Apprentissages', href: '/bilan/' },
  { label: 'Vision', href: '/vision/' },
  { label: 'À propos', href: '/a-propos/' },
];

const navLinksEn = [
  { label: 'Home', href: '/en/' },
  { label: 'Case Studies', href: '/en/etudes-de-cas/' },
  { label: 'Countries', href: '/en/pays-et-culture/' },
  { label: 'Skills', href: '/en/bilan/' },
  { label: 'Vision', href: '/en/vision/' },
  { label: 'About', href: '/en/a-propos/' },
];

const navLinks = locale === 'en' ? navLinksEn : navLinksFr;
const ctaLabel = locale === 'en' ? 'Download CV' : 'Télécharger CV';
const siteName = 'Grégor Van Dijk';
const homeHref = locale === 'en' ? '/en/' : '/';

function isActive(href: string): boolean {
  if (href === '/' || href === '/en/') return currentPath === href;
  return currentPath.startsWith(href);
}
---

<header class="sticky top-0 z-[1000] bg-surface border-b border-border">
  <nav aria-label={locale === 'en' ? 'Main navigation' : 'Navigation principale'} class="flex items-center justify-between h-16 px-6 max-w-[1320px] mx-auto">
    <!-- Logo -->
    <a href={homeHref} class="font-semibold text-primary hover:text-accent transition-colors duration-150">
      {siteName}
    </a>

    <!-- Desktop links -->
    <div class="hidden lg:flex items-center gap-6">
      {navLinks.map(link => (
        <a
          href={link.href}
          class:list={[
            'text-[0.8125rem] font-medium transition-colors duration-150',
            isActive(link.href)
              ? 'text-accent underline underline-offset-4 decoration-2'
              : 'text-primary hover:text-accent'
          ]}
          {...(isActive(link.href) ? { 'aria-current': 'page' } : {})}
        >
          {link.label}
        </a>
      ))}
      <BoutonCTA label={ctaLabel} href="/cv-gregor-vandijk.pdf" variant="primary" />
      <a
        href={alternatePath}
        class="text-xs font-semibold uppercase px-2.5 py-1 rounded border border-border text-secondary hover:text-accent hover:border-accent transition-colors duration-150"
        aria-label={locale === 'en' ? 'Switch to French' : 'Passer en anglais'}
      >
        {locale === 'en' ? 'FR' : 'EN'}
      </a>
    </div>

    <!-- Mobile hamburger menu -->
    <details class="lg:hidden group">
      <summary class="list-none cursor-pointer p-2 -mr-2">
        <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 6h18M3 12h18M3 18h18" />
        </svg>
        <span class="sr-only">Menu</span>
      </summary>
      <div class="absolute left-0 right-0 top-16 z-40 bg-surface border-t border-border shadow-sm">
        <div class="flex flex-col px-6 py-4 gap-1">
          {navLinks.map(link => (
            <a
              href={link.href}
              class:list={[
                'py-3 text-[0.9375rem] font-medium transition-colors duration-150',
                isActive(link.href)
                  ? 'text-accent'
                  : 'text-primary hover:text-accent'
              ]}
              {...(isActive(link.href) ? { 'aria-current': 'page' } : {})}
            >
              {link.label}
            </a>
          ))}
          <div class="flex items-center gap-3 pt-2">
            <BoutonCTA label={ctaLabel} href="/cv-gregor-vandijk.pdf" variant="primary" />
            <a
              href={alternatePath}
              class="text-xs font-semibold uppercase px-2.5 py-1 rounded border border-border text-secondary hover:text-accent hover:border-accent transition-colors duration-150"
              aria-label={locale === 'en' ? 'Switch to French' : 'Passer en anglais'}
            >
              {locale === 'en' ? 'FR' : 'EN'}
            </a>
          </div>
        </div>
      </div>
    </details>
  </nav>
</header>

<style>
  details summary::-webkit-details-marker {
    display: none;
  }
  details summary::marker {
    display: none;
  }
</style>
