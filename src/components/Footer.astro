---
import { getLocaleFromPath } from '../i18n/utils';

const currentYear = new Date().getFullYear();
const locale = getLocaleFromPath(Astro.url.pathname);
const newWindowLabel = locale === 'en' ? '(opens in new tab)' : '(nouvelle fenêtre)';
---

<footer class="bg-primary text-white">
  <div class="max-w-[1320px] mx-auto px-6 py-8">
    <div class="flex flex-col md:flex-row items-center justify-between gap-4">
      <div class="flex flex-wrap items-center justify-center gap-6 text-sm">
        <a href="#" data-u="vdijk.gregor" data-d="gmail.com" class="obf-email py-2 text-gray-300 hover:text-white focus-visible:text-white transition-colors duration-150">
          Email
        </a>
        <a href="https://linkedin.com/in/gregor-vandijk" class="py-2 text-gray-300 hover:text-white focus-visible:text-white transition-colors duration-150"
           target="_blank" rel="noopener noreferrer">
          LinkedIn <span class="sr-only">{newWindowLabel}</span>
        </a>
      </div>
      <p class="text-sm text-gray-300">
        © {currentYear} Grégor Van Dijk
      </p>
    </div>
  </div>
</footer>

<style>
  footer :focus-visible {
    outline-color: white;
  }
</style>
